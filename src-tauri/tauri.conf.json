{
  "$schema": "https://raw.githubusercontent.com/nicedoc/open-code/refs/heads/main/schemas/json/tauri-conf.schema.json",
  "productName": "OpenCode Monitor",
  "version": "0.1.4",
  "identifier": "com.opencode.monitor",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "OpenCode Monitor",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: https://asset.localhost; font-src 'self' data:"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": ["https://raw.githubusercontent.com/chandupalawattage/opencode-monitor/main/update.json"],
      "pubkey": "~/.tauri/opencode-monitor.pub",
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "msi",
    "icon": [
    "icons/32x32.png",
    "icons/128x128.png",
    "icons/128x128@2x.png",
    "icons/icon.ico"
  ],
    "windows": {
      "wix": {
        "language": "en-US"
      }
    },
    "copyright": "Copyright (c) 2025 OpenCode",
    "publisher": "OpenCode"
  }
}
