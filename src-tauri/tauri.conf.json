{
  "$schema": "https://raw.githubusercontent.com/nicedoc/open-code/refs/heads/main/schemas/json/tauri-conf.schema.json",
  "productName": "openCode Monitor",
  "version": "0.1.0",
  "identifier": "com.opencode.monitor",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "openCode Monitor",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "msi",
    "icon": [
    "icons/32x32.png",
    "icons/128x128.png",
    "icons/128x128@2x.png",
    "icons/icon.ico"
  ],
    "windows": {
      "wix": null
    }
  }
}
